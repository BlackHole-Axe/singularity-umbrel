#!/usr/bin/env bash
# Self-contained — Umbrel copies only this file out before deleting app-data.
set -euo pipefail
SINGULARITY_APP_ID="singularity-pool"
SINGULARITY_IMAGE_REPO="ghcr.io/blackhole-axe/singularity-pool"
docker ps -aq --filter "name=${SINGULARITY_APP_ID}_" 2>/dev/null | xargs -r docker rm -f 2>/dev/null || true
docker images "${SINGULARITY_IMAGE_REPO}" --format '{{.ID}}' 2>/dev/null | sort -u | xargs -r docker rmi -f 2>/dev/null || true
echo "SINGULARITY (${SINGULARITY_APP_ID}): removed all containers and images"
